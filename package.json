{
  "name": "ffmpeg-video-generator",
  "version": "2.0.0",
  "description": "Advanced video generator with AI integrations, job queue management, and batch processing",
  "main": "server-new.js",
  "scripts": {
    "start": "node server-new.js",
    "dev": "nodemon server-new.js",
    "start:old": "node server.js",
    "test": "echo \"No tests specified\" && exit 0",
    "test:apis": "node src/scripts/test-apis.js",
    "test:pipeline": "node src/scripts/test-pipeline.js",
    "test:video": "node src/scripts/test-complete-video.js",
    "test:person-overlay": "node src/scripts/test-person-overlay.js",
    "deploy": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop video-generator",
    "restart": "pm2 restart video-generator",
    "logs": "pm2 logs video-generator",
    "queue:monitor": "node src/queues/monitor.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@fal-ai/client": "^1.7.0",
    "assemblyai": "^4.16.1",
    "axios": "^1.7.7",
    "bull": "^4.12.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^11.1.1",
    "ioredis": "^5.4.1",
    "multer": "^2.0.2",
    "tar": "^6.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
