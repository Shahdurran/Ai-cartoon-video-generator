# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# File Upload Settings
MAX_FILE_SIZE=100mb
TEMP_DIR=/tmp/video-generator

# Video Processing Settings
MAX_VIDEO_DURATION=2700
DEFAULT_VIDEO_RESOLUTION=1920x1080

# Paths
EFFECTS_DIR=./effects
OUTPUT_DIR=./test-output
PUBLIC_DIR=./public

# Python/Whisper Configuration
PYTHON_PATH=/opt/whisper-env/bin/python
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# FFmpeg Configuration
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# =============================================================================
# AI Cartoon Generator -- New Services
# =============================================================================

# PostgreSQL (Railway injects DATABASE_URL automatically from the Postgres plugin)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
RUN_MIGRATIONS_ON_STARTUP=true
RUN_SEED_ON_STARTUP=true
PG_POOL_MAX=10
# Set to true to log every query timing (noisy — dev only)
PG_LOG_QUERIES=false

# Redis (Railway injects REDIS_URL; legacy granular vars also supported below)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cloudflare R2
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional -- if your bucket is fronted by a public CDN domain, set this for publicUrl() helpers
R2_PUBLIC_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Fal.AI (shared between Flux and Seedance)
FAL_KEY=
FAL_AI_API_KEY=
# Swap to Seedance 2.0 / Kling by changing this single value -- no code change required.
VIDEO_MODEL_ID=fal-ai/bytedance/seedance/v1/pro/image-to-video

# ElevenLabs (primary voice provider)
ELEVENLABS_API_KEY=
# Keep old voiceService providers alive during transition -- set to true to route through the legacy path.
USE_LEGACY_VOICE=false

# AssemblyAI
ASSEMBLYAI_API_KEY=

# Queue concurrency overrides (optional)
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_TIMEOUT=300000
QUEUE_MAX_CONCURRENT_JOBS=3
