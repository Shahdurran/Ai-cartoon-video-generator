# Backend API base URL.
# In dev: http://localhost:3000
# In Railway prod with rewrites: leave blank or set to /backend-api
NEXT_PUBLIC_API_URL=http://localhost:3000

# Internal URL used by next.config.js rewrites for Railway private networking.
# Set this when you want the backend to stay internal.
# BACKEND_INTERNAL_URL=http://backend.railway.internal:3000
